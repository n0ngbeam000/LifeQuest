# ── Django Core ────────────────────────────────────────────────────────────────
SECRET_KEY=your-long-random-secret-key-here
DEBUG=True

# ── Database (PostgreSQL) ───────────────────────────────────────────────────────
# The app connects to localhost:5432, database "lifequest_db", user "postgres".
# Only the password is read from this file.
DB_PASSWORD=your-postgres-password

# ── Email — Gmail SMTP ──────────────────────────────────────────────────────────
# Used for email verification and password reset.
# Use a Gmail App Password, NOT your normal Gmail password.
# Enable App Passwords at: https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# ── Google OAuth (optional) ─────────────────────────────────────────────────────
# Leave blank if you don't need Google login — username/password auth still works.
# Create credentials at: https://console.cloud.google.com/
# Authorised redirect URI: http://localhost:8000/accounts/google/login/callback/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
